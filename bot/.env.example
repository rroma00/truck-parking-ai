# ── Bot server ────────────────────────────────────────────────────────────────
# Public hostname of this bot service (no scheme, no trailing slash)
# e.g.  my-bot-service.up.railway.app
BOT_HOST=

# Port uvicorn listens on (Railway sets this automatically)
PORT=8000

# ── Backend API ───────────────────────────────────────────────────────────────
BACKEND_URL=https://truck-parking-ai-production.up.railway.app

# ── AI Services ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+18556845491
